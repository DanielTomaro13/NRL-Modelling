# Bookmaker auth for src/odds.py — copy to ".env" and fill in (".env" is gitignored).
# Load locally with:  set -a; source .env; set +a   then run:  python src/odds.py
# For the hosted site, add these as GitHub Actions secrets (Settings → Secrets → Actions).

# TAB (Tabcorp) — OAuth2. Either a short-lived access token (~3h)...
TAB_ACCESS_TOKEN=

# ...or, preferred, the client credentials so the code auto-refreshes its own token:
TAB_CLIENT_ID=
TAB_CLIENT_SECRET=

# Dabble (iOS app) — Bearer token captured from the app with Charles (~1h lifetime).
# Format: "Bearer eyJ..."   PointsBet and Sportsbet/Ladbrokes need no auth.
DABBLE_AUTH=
# DABBLE_DEVICE_ID=        # optional, from the app's x-device-id header
